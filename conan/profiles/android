# Conan 2 profile for Android cross-compilation.
#
# Invoke per-arch (gradle does this for you, but you can run it manually
# during the recipe audit — see docs/design/BUILDS-ANDROID.md §3.5):
#
#   uv run --no-project conan install . --profile android -s arch=armv8  --build=missing
#   uv run --no-project conan install . --profile android -s arch=x86_64 --build=missing
#
# Required env: ANDROID_NDK_HOME pointing at the NDK install root,
# e.g. D:\android-sdk\ndk\29.0.14206865.
#
# compiler.version: NDK 29.0.x ships clang 19. Bump if you upgrade the
# NDK. Verify locally with:
#   "$env:ANDROID_NDK_HOME\toolchains\llvm\prebuilt\windows-x86_64\bin\clang.exe" --version

[settings]
os=Android
# api_level=24 (Android 7.0 Nougat) is the floor where getifaddrs /
# freeifaddrs are declared in the NDK libc — required by usrsctp (the
# SCTP backend libdatachannel uses for reliable datachannels). Drops
# Android 5/6 support, ~98% of in-use devices unaffected.
os.api_level=24
arch=armv8
compiler=clang
compiler.version=19
compiler.libcxx=c++_shared
compiler.cppstd=gnu23
build_type=Release

[tool_requires]
cmake/3.27.0
# Ninja must be in PATH at build time because we force CMake to use the
# Ninja generator below. Without listing it here, recipes that don't
# tool_require ninja themselves get "CMAKE_MAKE_PROGRAM is not set".
ninja/[>=1.11]

[conf]
tools.android:ndk_path={{ os.getenv("ANDROID_NDK_HOME") }}
# Force Ninja so recipes don't fall back to "MinGW Makefiles" on Windows
# (Conan defaults to MinGW when compiler=clang + os=Windows host, which
# requires mingw32-make.exe on PATH — we don't ship that). Ninja is a
# transitive tool_require already in our dep graph.
tools.cmake.cmaketoolchain:generator=Ninja
